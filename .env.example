# ============================================
# BL GENIUS - CONFIGURATION
# Copier ce fichier en .env et modifier les valeurs
# ============================================

# ============================================
# BASE DE DONNEES (PostgreSQL)
# ============================================
POSTGRES_DB=blgenius
POSTGRES_USER=blgenius
POSTGRES_PASSWORD=changeme_secure_password

# URL complète (utilisée par l'application)
DATABASE_URL=postgresql://blgenius:changeme_secure_password@postgres:5432/blgenius

# ============================================
# REDIS (File d'attente Celery)
# ============================================
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ============================================
# CONFIGURATION CELERY WORKER
# ============================================
# Nombre de workers simultanés (ajuster selon les ressources CPU)
CELERY_WORKER_CONCURRENCY=2

# ============================================
# STOCKAGE
# ============================================
# Chemin absolu sur l'hôte pour les vidéos
VIDEO_STORAGE_PATH=./data/videos

# Chemin absolu pour les modèles YOLO
MODEL_STORAGE_PATH=./models

# Répertoire de sortie (dans le conteneur)
VIDEO_OUTPUT_DIR=/app/data/videos

# ============================================
# IA / YOLO
# ============================================
YOLO_MODEL_PATH=/app/models/yolov8m.pt
YOLO_CONFIDENCE=0.35
FRAME_SAMPLE_FPS=5.0

# ============================================
# FRONTEND
# ============================================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ============================================
# SECURITE
# ============================================
SECRET_KEY=changez_cette_cle_par_une_cle_securisee_de_32_caracteres

# ============================================
# ENVIRONNEMENT
# ============================================
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
